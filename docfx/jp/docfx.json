{
    "build": {
        "content": [{
            "files": [
                "docs/**/*.md",
                "docs/**/toc.yml",
                "toc.yml",
                "*.md"
            ],
            "exclude": ["obj/**", "_site/**"]
        }],
        "resource": [{
            "files": ["images/**", "docs/**/images/**"],
            "exclude": ["obj/**", "_site/**"]
        }],
        "overwrite": [{
            "files": ["apidoc/**.md"],
            "exclude": ["obj/**", "_site/**"]
        }],
        "dest": "_site",
        "globalMetadataFiles": ["global.json", "../../node_modules/igniteui-docfx-template/template/bundling.global.json"],
        "globalMetadata": {
            "_appFaviconPath": "../images/favicon.ico"
        },
        "fileMetadataFiles": [],
        "template": ["../../node_modules/igniteui-docfx-template/template"],
        "postProcessors": ["SetEnvironmentVariables"],
        "noLangKeyword": false,
        "keepFileLink": false,
        "cleanupCacheHistory": true,
        "disableGitFeatures": true,
        "sitemap": {
            "baseUrl": "https://www.infragistics.com/products/ignite-ui-angular/angular/",
            "changefreq": "weekly",
            "priority": 0.7,
            "fileOptions":{
                "**/analytics/**": {
                    "priority": 0.8
                },
                "**/first-time-sign-in.md": {
                    "priority": 0.9
                }
            }
        }
    }
}
