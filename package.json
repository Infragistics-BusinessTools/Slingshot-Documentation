{
  "name": "slingshot-docfx",
  "version": "1.0.0",
  "description": "Static sample site generator for Slingshot",
  "scripts": {
    "build:staging": "set NODE_ENV=staging && gulp ci-build",
    "build:prod": "set NODE_ENV=production && gulp ci-build",
    "build:staging_jp": "set NODE_ENV=staging && gulp ci-build --lang jp",
    "build:prod_jp": "set NODE_ENV=production && gulp ci-build --lang jp",
    "build": "gulp build",
    "start": "gulp serve",
    "build-staging": "set NODE_ENV=staging && gulp build",
    "build-production": "set NODE_ENV=production && gulp build",
    "build-staging_jp": "set NODE_ENV=staging && gulp build --lang jp",
    "build-production_jp": "set NODE_ENV=production && gulp build --lang jp",
    "postinstall": "dotnet tool restore"
  },
  "author": "Infragistics",
  "license": "ISC",
  "devDependencies": {
    "browser-sync": "^2.26.7",
    "del": "^6.0.0",
    "gulp": "^4.0.2",
    "gulp-insert": "^0.5.0",
    "gulp-replace": "^1.1.3",
    "igniteui-docfx-template": "^3.5.0",
    "robocopy": "^0.1.16",
    "slash": "^3.0.0",
    "yargs": "^12.0.5"
  }
}
