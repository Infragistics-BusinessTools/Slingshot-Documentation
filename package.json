    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc && gulp buildSlingshot --plat=Slingshot",
    "build-Slingshot": "tsc && gulp buildSlingshot --plat=Slingshot",
    "build-Angular": "tsc && gulp buildAngular",
    "build-React": "tsc && gulp buildReact",
    "build-WebComponents": "tsc && gulp buildWebComponents",
    "build-all": "tsc && gulp buildAll",
    "start": "tsc && gulp serve-slingshot --plat=Slingshot",
    "start-Slingshot": "tsc && gulp serve-site --plat=Slingshot",
    "start-WebComponents": "tsc && gulp serve-site --plat=WebComponents",
    "start-React": "tsc && gulp serve-site --plat=React",
    "build-docfx": "tsc && gulp build-docfx-Slingshot --plat=Slingshot",
    "build-staging": "tsc && set NODE_ENV=staging && gulp build-docfx-Slingshot --plat=Slingshot",
    "build-production": "tsc && set NODE_ENV=production && gulp build-docfx-Slingshot --plat=Slingshot",
    "init-app": "gulp initial-configuration && npm run build && npm run start"
